# CodeMind Backend Environment Variables
# Copy this file to .env and fill in the values.

# ── Neo4j (Temporal Knowledge Graph) ──
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=codemind_dev

# ── Qdrant (Vector Store) ──
QDRANT_HOST=localhost
QDRANT_PORT=6333

# ── Ollama (Local LLM) ──
OLLAMA_BASE_URL=http://localhost:11434

# ── Cloud LLM Fallback (optional) ──
OPENAI_API_KEY=
GEMINI_API_KEY=
